# Copy to terraform.tfvars and adjust as needed.
# terraform.tfvars is gitignored — do not commit real API keys.

# ── Emulator (default) ────────────────────────────────────────────────
ibmcloud_api_key = "local-dev-key"
emulator_url     = "http://localhost:4515"
region           = "us-south"
prefix           = "bluestack"

# ── Real IBM Cloud ─────────────────────────────────────────────────────
# Uncomment and fill in to run against real IBM Cloud instead of the emulator.
# ibmcloud_api_key  = "YOUR_REAL_API_KEY"
# emulator_url      = "https://us-south.iaas.cloud.ibm.com"
# region            = "us-south"
# resource_group_id = "YOUR_RESOURCE_GROUP_ID"
